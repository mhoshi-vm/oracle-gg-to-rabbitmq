# ==========================================================
# 1. ConnectionFactory Object
# ==========================================================
RMQConnectionFactory/ClassName=javax.jms.ConnectionFactory
RMQConnectionFactory/FactoryName=com.rabbitmq.jms.admin.RMQObjectFactory
RMQConnectionFactory/RefAddr/0/Content=jms/ConnectionFactory
RMQConnectionFactory/RefAddr/0/Type=name
RMQConnectionFactory/RefAddr/0/Encoding=String
RMQConnectionFactory/RefAddr/1/Content=javax.jms.ConnectionFactory
RMQConnectionFactory/RefAddr/1/Type=type
RMQConnectionFactory/RefAddr/1/Encoding=String
RMQConnectionFactory/RefAddr/2/Content=com.rabbitmq.jms.admin.RMQObjectFactory
RMQConnectionFactory/RefAddr/2/Type=factory
RMQConnectionFactory/RefAddr/2/Encoding=String
RMQConnectionFactory/RefAddr/3/Content=amqp://ggadmin:ggadmin123@rabbitmq:5672
RMQConnectionFactory/RefAddr/3/Type=uri
RMQConnectionFactory/RefAddr/3/Encoding=String

# ==========================================================
# 2. Destination Object (Queue bound to amq.topic exchange)
#
# Must be javax.jms.Queue, NOT Topic.
# The RabbitMQ JMS client always routes Topic publishes through
# its own jms.durable.topic exchange regardless of the name.
# Using Queue + amqpExchangeName bypasses that and publishes
# directly to the amq.topic AMQP exchange.
# ==========================================================
oracle.cdc/ClassName=javax.jms.Queue
oracle.cdc/FactoryName=com.rabbitmq.jms.admin.RMQObjectFactory
oracle.cdc/RefAddr/0/Content=jms/Queue
oracle.cdc/RefAddr/0/Type=name
oracle.cdc/RefAddr/0/Encoding=String
oracle.cdc/RefAddr/1/Content=javax.jms.Queue
oracle.cdc/RefAddr/1/Type=type
oracle.cdc/RefAddr/1/Encoding=String
oracle.cdc/RefAddr/2/Content=com.rabbitmq.jms.admin.RMQObjectFactory
oracle.cdc/RefAddr/2/Type=factory
oracle.cdc/RefAddr/2/Encoding=String
oracle.cdc/RefAddr/3/Content=oracle.cdc
oracle.cdc/RefAddr/3/Type=destinationName
oracle.cdc/RefAddr/3/Encoding=String
oracle.cdc/RefAddr/4/Content=amq.topic
oracle.cdc/RefAddr/4/Type=amqpExchangeName
oracle.cdc/RefAddr/4/Encoding=String
oracle.cdc/RefAddr/5/Content=oracle.cdc
oracle.cdc/RefAddr/5/Type=amqpRoutingKey
oracle.cdc/RefAddr/5/Encoding=String