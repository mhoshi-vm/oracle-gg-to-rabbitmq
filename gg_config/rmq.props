gg.handlerlist=jms
gg.handler.jms.type=jms

# Payload Formatting
gg.handler.jms.format=json
gg.handler.jms.format.metaColumnsTemplate=${optype},${primarykeys}

# Routing configurations
gg.handler.jms.connectionFactory=RMQConnectionFactory
gg.handler.jms.destinationTemplate=oracle.cdc

# =================================================================
# File System JNDI Properties
# =================================================================
java.naming.factory.initial=com.sun.jndi.fscontext.RefFSContextFactory
java.naming.provider.url=file:/u02/config/

# Classpath for the mounted JMS Jars
gg.classpath=/u02/jars/*