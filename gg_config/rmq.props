gg.handlerlist=jms
gg.handler.jms.type=jms

# Payload Formatting
gg.handler.jms.format=json
gg.handler.jms.format.metaColumnsTemplate=${optype},${primarykeys}

# Routing configurations (Updated for 23ai templates)
gg.handler.jms.connectionFactory=RMQConnectionFactory
gg.handler.jms.destinationTemplate=amq.topic

# =================================================================
# JNDI Properties
# =================================================================
java.naming.factory.initial=com.rabbitmq.jms.admin.RMQObjectFactory
java.naming.provider.url=amqp://ggadmin:ggadmin123@rabbitmq:5672
connectionFactoryNames=RMQConnectionFactory
topic.amq.topic=amq.topic

# Classpath for the mounted JMS Jars
gg.classpath=/u02/jars/*